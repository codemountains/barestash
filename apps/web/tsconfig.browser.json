{
  "compilerOptions": {
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "noEmitOnError": true,
    "outDir": "public/assets",
    "rootDir": "src/browser",
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022"
  },
  "include": ["src/browser/**/*.ts"],
  "exclude": ["src/browser/**/*.test.ts"]
}
